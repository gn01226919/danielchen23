# ── 後台 CMS（開發預設請上線必改）────────────────────────────
ADMIN_PASSWORD=
ADMIN_SECRET=

# 內容：file | supabase
# 正式站（Vercel）請用 supabase；本機可 file 或 supabase
CMS_DRIVER=supabase
# ── 公開（可進瀏覽器；必須搭配 RLS）──────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── 僅 Server（禁止 NEXT_PUBLIC_、禁止 commit 真實值）────────
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
RESEND_API_KEY=

# 寄件顯示（Resend 已驗證網域後改成你的）
# EMAIL_FROM=Daniel Chen <mentor@danielchen23.com>
EMAIL_FROM=

# 你「收」會員回饋的信箱（可為 Gmail，或 Cloudflare 轉寄進來的位址）
MENTOR_INBOX=
